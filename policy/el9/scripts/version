#!/usr/bin/env bash
set -eo pipefail

# Extract RPM version components from git tag.
# Tag format: v{version}.{channel}.{release}
# Example: v0.1.stable.1 → RPM_VERSION=0.1, RPM_CHANNEL=stable, RPM_RELEASE=1

if [ -z "${TAG}" ]; then
    TAG=$(git describe --tags --always --dirty 2>/dev/null || echo "v0.0.dev.0")
fi

if ! [[ "${TAG}" =~ ^v([0-9]+\.[0-9]+)\.(testing|stable)\.([0-9]+)$ ]]; then
    echo "error: tag '${TAG}' does not match format v{version}.{channel}.{release}" >&2
    echo "example: v0.1.stable.1" >&2
    exit 1
fi

export RPM_VERSION="${BASH_REMATCH[1]}"
export RPM_CHANNEL="${BASH_REMATCH[2]}"
export RPM_RELEASE="${BASH_REMATCH[3]}"

echo "RPM_VERSION=${RPM_VERSION}"
echo "RPM_CHANNEL=${RPM_CHANNEL}"
echo "RPM_RELEASE=${RPM_RELEASE}"
