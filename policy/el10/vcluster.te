policy_module(vcluster, 0.0.0)

########################################
#
# vCluster SELinux policy
#
# vCluster processes run under container_runtime_t from container-selinux
# rather than a custom domain. This is deliberate: the vcluster binary
# manages containerd, kubelet, etcd, and kube-apiserver as child processes
# requiring the same broad host access that container_runtime_t provides.
# A dedicated domain would need to replicate most of container_runtime_t's
# permissions, adding complexity without meaningful isolation.
# This follows the established pattern used by other Kubernetes distributions.
#

##### type: vcluster_data_t
# Data files: PKI certs, kine DB, konnectivity sockets, pid files
type vcluster_data_t;
files_type(vcluster_data_t)

gen_require(`
    attribute container_runtime_domain;
')

# container_runtime_domain can manage vcluster data files.
# Uses the module interface (no relabel permissions — prevents a
# compromised runtime from relabeling PKI/DB to container_file_t).
vcluster_manage_data(container_runtime_domain)

##### container_t -> kernel_t:tcp_socket { read write }
# Inbound TCP sockets accepted by the kernel arrive labeled kernel_t.
# RHEL/Rocky's container-selinux grants container_t access to them
# implicitly; Amazon Linux 2023's fork does not, which causes every
# readiness/liveness probe and incoming service connection to be RST'd
# at the userspace boundary (e.g. coredns stuck 0/1 Ready).
# Both read and write are required: read for the request, write for
# the response — coredns hits the write denial when answering /ready.
gen_require(`
    type container_t;
    type kernel_t;
')

allow container_t kernel_t:tcp_socket { read write };
